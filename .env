# API Keys and Configuration
YFINANCE_CACHE_DIR=./data/raw/yfinance_cache
COINGECKO_API_KEY=free_tier
WORLD_GOLD_COUNCIL_API_KEY=placeholder_wgc_api_key

# VPS Configuration
VPS_CONFIG_PATH=config/vps_list.csv

# Data Paths
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed
CONFIG_DIR=./config

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Request Settings
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=0.5

# SSH Settings
SSH_TIMEOUT=10
SSH_PORT_DEFAULT=22
